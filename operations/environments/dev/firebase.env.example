# Development Firebase binding
# Populate these values in a local untracked .env file or in CI secrets.
CASA_FIREBASE_PROJECT_DEV=
CASA_FIREBASE_WEB_APP_ID_DEV=
CASA_FIREBASE_AUTH_DOMAIN_DEV=
CASA_FIREBASE_STORAGE_BUCKET_DEV=
CASA_FIREBASE_MESSAGING_SENDER_ID_DEV=
CASA_FIREBASE_API_KEY_DEV=
# Optional analytics measurement identifier. Keep blank when Analytics is not used.
CASA_FIREBASE_MEASUREMENT_ID_DEV=