# Staging Firebase binding
# Populate these values in a local untracked .env file or in CI secrets.
CASA_FIREBASE_PROJECT_STAGING=
CASA_FIREBASE_WEB_APP_ID_STAGING=
CASA_FIREBASE_AUTH_DOMAIN_STAGING=
CASA_FIREBASE_STORAGE_BUCKET_STAGING=
CASA_FIREBASE_MESSAGING_SENDER_ID_STAGING=
CASA_FIREBASE_API_KEY_STAGING=
# Optional analytics measurement identifier. Keep blank when Analytics is not used.
CASA_FIREBASE_MEASUREMENT_ID_STAGING=